<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="128"
        Width="350" Height="128"
        MinWidth="250" MinHeight="128"
        x:Class="Client.Dialogs.ModalDialog"
        Title="Modal">
    <Grid RowDefinitions="Auto,*,Auto" Background="#303030">
        <Border Grid.Row="0" Margin="8" CornerRadius="8" Background="#202020" ClipToBounds="True">
            <TextBlock Margin="8" Name="Message" TextWrapping="WrapWithOverflow"/>
        </Border>
        
        <Border Grid.Row="2" Margin="8" CornerRadius="8" Background="#202020" ClipToBounds="True">
            <Grid ColumnDefinitions="Auto,*,Auto" Background="#202020">
                <Button Grid.Column="2" Margin="8" Name="YesButton" Click="YesButton_OnClick"></Button>
                <Button Grid.Column="0" Margin="8" Name="NoButton" Click="NoButton_OnClick"></Button>
            </Grid>
        </Border>
    </Grid>
</Window>
