<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        MinWidth="800" MinHeight="500"
        Width="800" Height="500"
        x:Class="Client.Dialogs.SettingsDialog"
        Title="Settings">
    <Grid RowDefinitions="Auto,*,Auto" Background="#303030">
        <Border Grid.Row="0" Margin="8" CornerRadius="8" Background="#202020" ClipToBounds="True">
            <Grid ColumnDefinitions="Auto,*" Background="#202020">
                <TextBlock Grid.Column="0" Margin="8 8 2 8" Text="Server URL" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="2 8 8 8" Name="ServerUrlTextBox" PlaceholderText="Server URL..." VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <Border Grid.Row="2" Margin="8" CornerRadius="8" Background="#202020" ClipToBounds="True">
            <Grid ColumnDefinitions="Auto,*,Auto" Background="#202020">
                <Button Grid.Column="0" Margin="8" Name="CancelButton" Click="CancelButton_OnClick" Content="Cancel"/>
                <Button Grid.Column="2" Margin="8" Name="SaveAndRestartButton" Click="SaveAndRestartButton_OnClick" Content="Save and Restart"/>
            </Grid>
        </Border>
    </Grid>
    
</Window>
